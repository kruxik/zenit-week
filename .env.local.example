# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Used by: api/token.js (Vercel Edge Function for Google OAuth token exchange)
# Local dev: run `vercel dev` instead of opening the HTML file directly.
#
# Create your own OAuth 2.0 credentials at:
#   https://console.cloud.google.com/apis/credentials
#   Application type: Web application
#   Authorized redirect URIs: http://localhost:3000/app

GOOGLE_CLIENT_SECRET=your_google_client_secret_here
